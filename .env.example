# Required in production (Vercel: Project → Settings → Environment Variables)
SESSION_SECRET=
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=

# Optional: canonical URL for OG/social metadata.
# On Vercel this falls back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL automatically.
# Set this when you add a custom domain, e.g. https://viz.example.com
NEXT_PUBLIC_SITE_URL=
